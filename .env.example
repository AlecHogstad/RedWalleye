# Product Supabase project (the NEW project, separate from the v1 kv app).
# Copy this file to .env.local and fill in your project's values, then restart
# `npm run dev`. Both are public identifiers (anon key is safe in the browser;
# access is governed by RLS). Dashboard → Project Settings → API.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
